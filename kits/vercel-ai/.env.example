# Circle Agent Stack
# Authentication is handled by the Circle CLI itself. There is no Circle API
# key. The demo handles login (email + OTP) and Terms acceptance on first run.
# https://developers.circle.com/agent-stack

# LLM provider — set ONE of the two keys below. ANTHROPIC_API_KEY is checked
# first; if absent, OPENAI_API_KEY is used. The default models are:
#   Anthropic: claude-sonnet-4-6
#   OpenAI:    gpt-4.1
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: override the model (raw model ID, no provider prefix,
# e.g. "claude-opus-4-7" or "gpt-4o-mini")
# LLM_MODEL=

# Optional: override the chain (default: BASE)
# CIRCLE_CHAIN=BASE
