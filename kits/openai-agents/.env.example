# Circle Agent Stack
# Authentication is handled by the Circle CLI itself. There is no Circle API
# key. The demo handles login (email + OTP) and Terms acceptance on first run.
# https://developers.circle.com/agent-stack

# OpenAI API key (required). This kit uses the OpenAI Agents SDK, which only
# supports OpenAI-compatible models. For Anthropic model support, use the
# langchain or claude-agent-sdk kit instead.
OPENAI_API_KEY=

# Optional: override the OpenAI model (default: gpt-4.1)
# LLM_MODEL=gpt-4o-mini

# Optional: override the chain (default: BASE)
# CIRCLE_CHAIN=BASE
