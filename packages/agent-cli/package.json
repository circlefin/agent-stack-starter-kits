{
  "name": "@agent-stack-ecosystem-kits/agent-cli",
  "version": "0.0.0",
  "private": true,
  "description": "Reusable Ink-based terminal chat UI (scrolling log + pinned bottom input) shared by the agent kits.",
  "type": "module",
  "main": "./src/index.tsx",
  "types": "./src/index.tsx",
  "exports": {
    ".": "./src/index.tsx"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "typescript": "^5.5.0"
  }
}
